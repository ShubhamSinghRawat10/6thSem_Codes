<?php 
session_start();

// Session variables
$_SESSION["USER"] = "Shubham Singh Rawat";
$_SESSION["course"] = "B.Tech";

// Set cookie
setcookie("username", "Shubham", time() + 3600);
?>

<!DOCTYPE html>
<html>
<head>
    <title>Session and Cookies</title>
</head>

<body>

<?php

echo "<h3>Cookie Demo:</h3>";

if (isset($_COOKIE["username"])) {
    echo "Cookie Value: " . $_COOKIE["username"];
} 
else {
    echo "Cookie is not set yet";
}

?>

</body>
</html>